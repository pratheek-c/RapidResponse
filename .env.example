# ─── AWS Credentials ──────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
# AWS_SESSION_TOKEN=        # Only needed for temporary/assumed-role credentials
# AWS_PROFILE=              # Optional: use a named AWS profile instead of key/secret

# ─── Bedrock Model IDs ────────────────────────────────────────────────────────
# Cross-region inference profile format (recommended for us-east-1)
BEDROCK_NOVA_SONIC_MODEL_ID=us.amazon.nova-sonic-v1:0
BEDROCK_NOVA_LITE_MODEL_ID=us.amazon.nova-lite-v1:0
BEDROCK_TITAN_EMBED_MODEL_ID=us.amazon.titan-embed-text-v2:0
# If using a direct regional endpoint (e.g. eu-north-1 sandbox):
# BEDROCK_NOVA_SONIC_MODEL_ID=amazon.nova-2-sonic-v1:0

# ─── libSQL Database ──────────────────────────────────────────────────────────
# Embedded file mode — default, no external service needed
LIBSQL_URL=file:./data/rapidresponse.db
# Networked mode — run sqld locally: docker run -p 8080:8080 ghcr.io/tursodatabase/libsql-server
# LIBSQL_URL=http://localhost:8080
# LIBSQL_AUTH_TOKEN=        # Only needed when sqld is configured with auth

# ─── S3 ───────────────────────────────────────────────────────────────────────
S3_BUCKET_NAME=rapidresponse-recordings
S3_RECORDINGS_PREFIX=recordings/

# ─── LanceDB ──────────────────────────────────────────────────────────────────
LANCEDB_PATH=./data/lancedb

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
FRONTEND_URL=http://localhost:5173

# ─── Dispatch Context ─────────────────────────────────────────────────────────
# Injected into Nova Sonic system prompt on every call
DISPATCH_CITY=Springfield
DISPATCH_DEPT=Springfield Emergency Services

# ─── Frontend (Vite) ──────────────────────────────────────────────────────────
# Firebase — required for dispatcher Google SSO login
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_firebase_app_id

# Backend URLs — only needed in production builds (Vite dev proxy handles local dev)
# VITE_API_BASE=https://api.yourdomain.com
# VITE_WS_BASE=wss://api.yourdomain.com
