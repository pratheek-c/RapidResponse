# AWS Credentials
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key

# Bedrock Model IDs
BEDROCK_NOVA_SONIC_MODEL_ID=amazon.nova-2-sonic-v1:0
BEDROCK_NOVA_LITE_MODEL_ID=amazon.nova-lite-v1:0
BEDROCK_TITAN_EMBED_MODEL_ID=amazon.titan-embed-text-v2:0

# libSQL — embedded file mode (default, no external service needed)
# For sqld networked mode: http://localhost:8080
LIBSQL_URL=file:./data/rapidresponse.db
# LIBSQL_AUTH_TOKEN=   # Only needed when using sqld with auth

# S3
S3_BUCKET_NAME=rapidresponse-recordings
S3_RECORDINGS_PREFIX=recordings/

# LanceDB
LANCEDB_PATH=./data/lancedb

# Server
PORT=3000
FRONTEND_URL=http://localhost:5173

# Dispatch Context (injected into Nova Sonic system prompt)
DISPATCH_CITY=Springfield
DISPATCH_DEPT=Springfield Emergency Services
